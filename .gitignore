# Local model dumps at repo root. Gazebo runtime models under src/robot_gz/models are tracked.
# Keep the simulation YOLO/NCNN model versioned so main is reproducible for dev PCs.
/models/*
!/models/yolo26n_ncnn_model/
!/models/yolo26n_ncnn_model/metadata.yaml
!/models/yolo26n_ncnn_model/model.ncnn.bin
!/models/yolo26n_ncnn_model/model.ncnn.param
!/models/yolo26n_ncnn_model/model_ncnn.py

