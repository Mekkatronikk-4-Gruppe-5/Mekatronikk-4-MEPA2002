#include <Wire.h>
#include <vl53l4ed_class.h>

#define XSHUT_PIN 7

const int OFFSET_MM = 15;

VL53L4ED sensor(&Wire, XSHUT_PIN);

void setup() {
  Serial.begin(115200);
  delay(2000);

  Serial.println("Starter VL53L4ED...");

  Wire.begin();           // Arduino Mega: SDA = 20, SCL = 21
  Wire.setClock(100000);  // Stabil I2C-hastighet

  // Reset sensoren via XSHUT
  pinMode(XSHUT_PIN, OUTPUT);
  digitalWrite(XSHUT_PIN, LOW);
  delay(200);
  digitalWrite(XSHUT_PIN, HIGH);
  delay(1000);

  int status;

  status = sensor.begin();
  Serial.print("begin status: ");
  Serial.println(status);

  if (status != 0) {
    Serial.println("sensor.begin() feilet");
    while (1);
  }

  status = sensor.InitSensor();
  Serial.print("InitSensor status: ");
  Serial.println(status);

  if (status != 0) {
    Serial.println("InitSensor() feilet");
    while (1);
  }

  status = sensor.VL53L4ED_StartRanging();
  Serial.print("StartRanging status: ");
  Serial.println(status);

  if (status != 0) {
    Serial.println("StartRanging() feilet");
    while (1);
  }

  Serial.println("VL53L4ED klar!");
}

void loop() {
  uint8_t dataReady = 0;
  VL53L4ED_ResultsData_t result;

  int status = sensor.VL53L4ED_CheckForDataReady(&dataReady);

  if (status != 0) {
    Serial.print("CheckForDataReady feil: ");
    Serial.println(status);
    delay(500);
    return;
  }

  if (dataReady) {
    sensor.VL53L4ED_ClearInterrupt();
    sensor.VL53L4ED_GetResult(&result);

    int rawDistance = result.distance_mm;
    int calibratedDistance = rawDistance - OFFSET_MM;

    // Hindrer negativ avstand
    if (calibratedDistance < 0) {
      calibratedDistance = 0;
    }

    Serial.print("Rå avstand: ");
    Serial.print(rawDistance);
    Serial.print(" mm | Kalibrert avstand: ");
    Serial.print(calibratedDistance);
    Serial.println(" mm");
  }

  delay(20);
}