<?xml version="1.0"?>
<robot name="tracked_robot">
  <material name="blue_body">
    <color rgba="0.2 0.2 0.9 1.0"/>
  </material>
  <material name="dark_gray">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="rubber_track">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>
  <material name="light_gray">
    <color rgba="0.4 0.4 0.4 1.0"/>
  </material>
  <material name="red_camera">
    <color rgba="0.9 0.2 0.2 1.0"/>
  </material>
  <material name="green_lidar">
    <color rgba="0.2 0.9 0.2 1.0"/>
  </material>

  <link name="chassis">
    <inertial>
      <origin xyz="-0.048 0 0.022" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.0417" ixy="0.0" ixz="0.0" iyy="0.0667" iyz="0.0" izz="0.0917"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.297 0.16 0.085"/>
      </geometry>
      <material name="blue_body"/>
    </visual>
    <visual>
      <origin xyz="0 0.096 -0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.19 0.038 0.09"/>
      </geometry>
      <material name="rubber_track"/>
    </visual>
    <visual>
      <origin xyz="0 -0.096 -0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.19 0.038 0.09"/>
      </geometry>
      <material name="rubber_track"/>
    </visual>
    <visual>
      <origin xyz="0.095 0.096 -0.02" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.038"/>
      </geometry>
      <material name="rubber_track"/>
    </visual>
    <visual>
      <origin xyz="-0.095 0.096 -0.02" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.038"/>
      </geometry>
      <material name="rubber_track"/>
    </visual>
    <visual>
      <origin xyz="0.095 -0.096 -0.02" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.038"/>
      </geometry>
      <material name="rubber_track"/>
    </visual>
    <visual>
      <origin xyz="-0.095 -0.096 -0.02" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.038"/>
      </geometry>
      <material name="rubber_track"/>
    </visual>
    <visual>
      <origin xyz="-0.06 0.096 -0.055" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.04"/>
      </geometry>
      <material name="light_gray"/>
    </visual>
    <visual>
      <origin xyz="0 0.096 -0.055" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.04"/>
      </geometry>
      <material name="light_gray"/>
    </visual>
    <visual>
      <origin xyz="0.06 0.096 -0.055" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.04"/>
      </geometry>
      <material name="light_gray"/>
    </visual>
    <visual>
      <origin xyz="-0.06 -0.096 -0.055" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.04"/>
      </geometry>
      <material name="light_gray"/>
    </visual>
    <visual>
      <origin xyz="0 -0.096 -0.055" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.04"/>
      </geometry>
      <material name="light_gray"/>
    </visual>
    <visual>
      <origin xyz="0.06 -0.096 -0.055" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.04"/>
      </geometry>
      <material name="light_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.297 0.21 0.085"/>
      </geometry>
    </collision>
  </link>
  <link name="caster_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.00008" ixy="0.0" ixz="0.0" iyy="0.00008" iyz="0.0" izz="0.00008"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
    </collision>
  </link>
  <joint name="caster_joint" type="fixed">
    <origin xyz="0.11 0 -0.07" rpy="0 0 0"/>
    <parent link="chassis"/>
    <child link="caster_wheel"/>
  </joint>

  <link name="left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.00065" ixy="0.0" ixz="0.0" iyy="0.00065" iyz="0.0" izz="0.00113"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <origin xyz="-0.035 0.093 -0.02" rpy="-1.5708 0 0"/>
    <parent link="chassis"/>
    <child link="left_wheel"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.00065" ixy="0.0" ixz="0.0" iyy="0.00065" iyz="0.0" izz="0.00113"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <origin xyz="-0.035 -0.093 -0.02" rpy="-1.5708 0 0"/>
    <parent link="chassis"/>
    <child link="right_wheel"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.02 0.01"/>
      </geometry>
      <material name="light_gray"/>
    </visual>
  </link>
  <joint name="imu_joint" type="fixed">
    <origin xyz="0.11 0 0.03" rpy="0 0 0"/>
    <parent link="chassis"/>
    <child link="imu_link"/>
  </joint>

  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.05 0.03"/>
      </geometry>
      <material name="red_camera"/>
    </visual>
  </link>
  <joint name="camera_joint" type="fixed">
    <origin xyz="0.125 0 0.06" rpy="0 0 0"/>
    <parent link="chassis"/>
    <child link="camera_link"/>
  </joint>

  <link name="lidar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0" iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.04"/>
      </geometry>
      <material name="green_lidar"/>
    </visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <origin xyz="0.0 -0.06 0.065" rpy="0 0 0"/>
    <parent link="chassis"/>
    <child link="lidar_link"/>
  </joint>
</robot>
