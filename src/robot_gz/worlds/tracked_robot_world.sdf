<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="robot_world">

    <!-- ========================= -->
    <!--        Physics             -->
    <!-- ========================= -->
    <physics name="2_5ms" type="ignored">
      <max_step_size>0.0025</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>400</real_time_update_rate>
    </physics>

    <!-- ========================= -->
    <!--        Plugins             -->
    <!-- ========================= -->

    <!-- Physics plugin -->
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>

    <!-- User commands (spawn/delete models via GUI) -->
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>

    <!-- Scene broadcaster (renders the scene) -->
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>

    <!-- Sensors plugin (camera, lidar, etc.) -->
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- Contact plugin -->
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>

    <!-- ========================= -->
    <!--        Lighting            -->
    <!-- ========================= -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- ========================= -->
    <!--      Ground Plane          -->
    <!-- ========================= -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
      </link>
    </model>


    <model name="lidar_obstacle_box1">
      <static>true</static>
      <pose>2 0 0.2 0 0 0</pose> <!-- x y z roll pitch yaw -->
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.4 0.4 0.4</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.4 0.4 0.4</size>
            </box>
          </geometry>
          <material>
            <ambient>0.9 0.2 0.2 1</ambient>
            <diffuse>0.9 0.2 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>


    <model name="lidar_obstacle_box3">
      <static>true</static>
      <pose>0 2 0.2 0 0 0</pose> <!-- x y z roll pitch yaw -->
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.4 0.4 0.4</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.4 0.4 0.4</size>
            </box>
          </geometry>
          <material>
            <ambient>0.9 0.2 0.2 1</ambient>
            <diffuse>0.9 0.2 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>


    <model name="lidar_obstacle_box2">
      <static>true</static>
      <pose>0 -2 0.2 0 0 0</pose> <!-- x y z roll pitch yaw -->
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.4 0.4 0.4</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.4 0.4 0.4</size>
            </box>
          </geometry>
          <material>
            <ambient>0.9 0.2 0.2 1</ambient>
            <diffuse>0.9 0.2 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>




    <!-- ========================= -->
    <!--   Tracked Robot            -->
    <!-- ========================= -->
    <model name="tracked_robot">
      <pose>0 0 0.06 0 0 0</pose>

      <!-- ===== Chassis (body) ===== -->
      <link name="chassis">
        <pose>0 0 0.025 0 0 0</pose>
        <inertial>
          <pose>-0.048 0 0.022 0 0 0</pose>
          <mass>5.0</mass>
          <inertia>
            <ixx>0.0417</ixx>
            <iyy>0.0667</iyy>
            <izz>0.0917</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="chassis_collision">
          <geometry>
            <box>
              <size>0.297 0.21 0.085</size>
            </box>
          </geometry>
        </collision>
        <visual name="chassis_visual">
          <geometry>
            <box>
              <size>0.297 0.16 0.085</size>
            </box>
          </geometry>
          <material>
            <ambient>0.1 0.1 0.8 1</ambient>
            <diffuse>0.2 0.2 0.9 1</diffuse>
            <specular>0.5 0.5 0.5 1</specular>
          </material>
        </visual>
        <visual name="left_track_belt_visual">
          <pose>0 0.096 -0.02 0 0 0</pose>
          <geometry>
            <box>
              <size>0.19 0.038 0.09</size>
            </box>
          </geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.12 0.12 0.12 1</diffuse>
            <specular>0.02 0.02 0.02 1</specular>
          </material>
        </visual>
        <visual name="right_track_belt_visual">
          <pose>0 -0.096 -0.02 0 0 0</pose>
          <geometry>
            <box>
              <size>0.19 0.038 0.09</size>
            </box>
          </geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.12 0.12 0.12 1</diffuse>
            <specular>0.02 0.02 0.02 1</specular>
          </material>
        </visual>
        <visual name="left_track_front_idler_visual">
          <pose>0.095 0.096 -0.02 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.045</radius>
              <length>0.038</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.12 0.12 0.12 1</diffuse>
            <specular>0.02 0.02 0.02 1</specular>
          </material>
        </visual>
        <visual name="left_track_rear_idler_visual">
          <pose>-0.095 0.096 -0.02 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.045</radius>
              <length>0.038</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.12 0.12 0.12 1</diffuse>
            <specular>0.02 0.02 0.02 1</specular>
          </material>
        </visual>
        <visual name="right_track_front_idler_visual">
          <pose>0.095 -0.096 -0.02 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.045</radius>
              <length>0.038</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.12 0.12 0.12 1</diffuse>
            <specular>0.02 0.02 0.02 1</specular>
          </material>
        </visual>
        <visual name="right_track_rear_idler_visual">
          <pose>-0.095 -0.096 -0.02 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.045</radius>
              <length>0.038</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.12 0.12 0.12 1</diffuse>
            <specular>0.02 0.02 0.02 1</specular>
          </material>
        </visual>
        <visual name="left_track_roller_front_visual">
          <pose>-0.06 0.096 -0.055 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.02</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.45 0.45 0.45 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
        <visual name="left_track_roller_mid_visual">
          <pose>0 0.096 -0.055 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.02</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.45 0.45 0.45 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
        <visual name="left_track_roller_rear_visual">
          <pose>0.06 0.096 -0.055 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.02</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.45 0.45 0.45 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
        <visual name="right_track_roller_front_visual">
          <pose>-0.06 -0.096 -0.055 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.02</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.45 0.45 0.45 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
        <visual name="right_track_roller_mid_visual">
          <pose>0 -0.096 -0.055 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.02</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.45 0.45 0.45 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
        <visual name="right_track_roller_rear_visual">
          <pose>0.06 -0.096 -0.055 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.02</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.45 0.45 0.45 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
      </link>

      <!-- ===== Simple Suspended Track Modules ===== -->
      <link name="front_left_track">
        <pose>0.065 0.082 -0.045 0 0 0</pose>
        <inertial>
          <mass>0.12</mass>
          <inertia>
            <ixx>0.00012</ixx>
            <iyy>0.00018</iyy>
            <izz>0.00018</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="front_left_track_collision">
          <geometry>
            <box>
              <size>0.11 0.036 0.03</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.7</mu>
                <mu2>150</mu2>
                <fdir1>1 0 0</fdir1>
              </ode>
            </friction>
          </surface>
        </collision>
      </link>

      <joint name="front_left_track_joint" type="prismatic">
        <parent>chassis</parent>
        <child>front_left_track</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-0.018</lower>
            <upper>0.012</upper>
          </limit>
          <dynamics>
            <spring_reference>0</spring_reference>
            <spring_stiffness>1500</spring_stiffness>
            <damping>55</damping>
          </dynamics>
        </axis>
      </joint>

      <link name="rear_left_track">
        <pose>-0.07 0.082 -0.045 0 0 0</pose>
        <inertial>
          <mass>0.12</mass>
          <inertia>
            <ixx>0.00012</ixx>
            <iyy>0.00018</iyy>
            <izz>0.00018</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="rear_left_track_collision">
          <geometry>
            <box>
              <size>0.11 0.036 0.03</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.7</mu>
                <mu2>150</mu2>
                <fdir1>1 0 0</fdir1>
              </ode>
            </friction>
          </surface>
        </collision>
      </link>

      <joint name="rear_left_track_joint" type="prismatic">
        <parent>chassis</parent>
        <child>rear_left_track</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-0.02</lower>
            <upper>0.012</upper>
          </limit>
          <dynamics>
            <spring_reference>0</spring_reference>
            <spring_stiffness>900</spring_stiffness>
            <damping>35</damping>
          </dynamics>
        </axis>
      </joint>

      <link name="front_right_track">
        <pose>0.065 -0.082 -0.045 0 0 0</pose>
        <inertial>
          <mass>0.12</mass>
          <inertia>
            <ixx>0.00012</ixx>
            <iyy>0.00018</iyy>
            <izz>0.00018</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="front_right_track_collision">
          <geometry>
            <box>
              <size>0.11 0.036 0.03</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.7</mu>
                <mu2>150</mu2>
                <fdir1>1 0 0</fdir1>
              </ode>
            </friction>
          </surface>
        </collision>
      </link>

      <joint name="front_right_track_joint" type="prismatic">
        <parent>chassis</parent>
        <child>front_right_track</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-0.018</lower>
            <upper>0.012</upper>
          </limit>
          <dynamics>
            <spring_reference>0</spring_reference>
            <spring_stiffness>1500</spring_stiffness>
            <damping>55</damping>
          </dynamics>
        </axis>
      </joint>

      <link name="rear_right_track">
        <pose>-0.07 -0.082 -0.045 0 0 0</pose>
        <inertial>
          <mass>0.12</mass>
          <inertia>
            <ixx>0.00012</ixx>
            <iyy>0.00018</iyy>
            <izz>0.00018</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="rear_right_track_collision">
          <geometry>
            <box>
              <size>0.11 0.036 0.03</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.7</mu>
                <mu2>150</mu2>
                <fdir1>1 0 0</fdir1>
              </ode>
            </friction>
          </surface>
        </collision>
      </link>

      <joint name="rear_right_track_joint" type="prismatic">
        <parent>chassis</parent>
        <child>rear_right_track</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-0.02</lower>
            <upper>0.012</upper>
          </limit>
          <dynamics>
            <spring_reference>0</spring_reference>
            <spring_stiffness>900</spring_stiffness>
            <damping>35</damping>
          </dynamics>
        </axis>
      </joint>

      <!-- ===== Left Wheel ===== -->
      <link name="left_wheel">
        <pose>-0.035 0.093 0.005 -1.5708 0 0</pose>
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.00065</ixx>
            <iyy>0.00065</iyy>
            <izz>0.00113</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="left_wheel_visual">
          <geometry>
            <cylinder>
              <radius>0.05</radius>
              <length>0.03</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.2 0.2 0.2 1</diffuse>
          </material>
        </visual>
      </link>

      <joint name="left_wheel_joint" type="revolute">
        <parent>chassis</parent>
        <child>left_wheel</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <!-- ===== Right Wheel ===== -->
      <link name="right_wheel">
        <pose>-0.035 -0.093 0.005 -1.5708 0 0</pose>
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.00065</ixx>
            <iyy>0.00065</iyy>
            <izz>0.00113</izz>
            <ixy>0</ixy>
